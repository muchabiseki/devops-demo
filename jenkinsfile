pipeline {
    agent any

    environment {
        IMAGE_NAME = 'muchabiseki/devops-demo'
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                // Clone the main branch of your repo
                checkout([$class: 'GitSCM',
                          branches: [[name: 'refs/heads/main']],
                          userRemoteConfigs: [[url: 'https://github.com/muchabiseki/devops-demo.git']]])
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def appDir = 'app' // relative to repo root after checkout
                    // Use Jenkins Docker plugin to build image
                    dockerImage = docker.build("${env.IMAGE_NAME}:${env.BUILD_NUMBER}", "-f ${appDir}/Dockerfile ${appDir}")
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                // Push the image to a local Docker registry (or local cache)
                sh 'docker push muchabiseki/devops-demo:$BUILD_NUMBER'
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    // Run tests inside the Docker image
                    docker.image("${env.IMAGE_NAME}:${env.BUILD_NUMBER}").inside {
                        sh 'pytest'
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs() // clean workspace after every build
        }
    }
}
