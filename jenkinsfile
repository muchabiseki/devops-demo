pipeline {
    agent {
        docker {
            image 'bitnami/kubectl:latest'
            args '-v /var/run/docker.sock:/var/run/docker.sock -v $HOME/.kube:/root/.kube --entrypoint=""'
        }
    }

    environment {
        IMAGE_NAME = 'local/devops-demo'
        IMAGE_TAG  = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout([$class: 'GitSCM',
                          branches: [[name: 'refs/heads/main']],
                          userRemoteConfigs: [[url: 'https://github.com/muchabiseki/devops-demo.git']]])
                sh 'ls -l'
                sh 'ls -l app'
                sh 'ls -l k8s'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def appDir = 'app' // folder containing Dockerfile
                    dockerImage = docker.build("${env.IMAGE_NAME}:${env.IMAGE_TAG}", "-f ${appDir}/Dockerfile ${appDir}")
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    // Skipping tests for now
                    echo 'Skipping tests for now'
                // Example if you add tests:
                // docker.image("${env.IMAGE_NAME}:${env.IMAGE_TAG}").inside {
                //     sh 'pytest -v /tests'
                // }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    sh '''
                        echo "Checking cluster connectivity..."
                        kubectl cluster-info
                        kubectl get nodes

                        echo "Deploying to Kubernetes..."
                        kubectl apply -f k8s/deployment.yaml --validate=false
                        kubectl apply -f k8s/service.yaml --validate=false

                        echo "Waiting for rollout..."
                        kubectl rollout status deployment/devops-demo
                    '''
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
