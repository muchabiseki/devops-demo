pipeline {
    agent any

    environment {
        IMAGE_NAME = 'local/devops-demo'
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout([$class: 'GitSCM',
                          branches: [[name: 'refs/heads/main']],
                          userRemoteConfigs: [[url: 'https://github.com/muchabiseki/devops-demo.git']]])
                sh 'ls -l'
                sh 'ls -l app'
                sh 'ls -l k8s'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def appDir = 'app' // folder containing Dockerfile
                    dockerImage = docker.build("${env.IMAGE_NAME}:${env.BUILD_NUMBER}", "-f ${appDir}/Dockerfile ${appDir}")
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    // If you add tests back, mount them like this
                    // docker.image("${env.IMAGE_NAME}:${env.BUILD_NUMBER}").inside("-v ${env.WORKSPACE}/tests:/tests") {
                    //     sh 'pytest -v /tests'
                    // }
                    echo 'Skipping tests for now'
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    docker.image('bitnami/kubectl:latest').inside("--entrypoint='' -v $HOME/.kube:/root/.kube") {
                        sh '''
                    echo "Checking cluster connectivity..."

                    # Use host.docker.internal for Docker Desktop
                    export KUBERNETES_MASTER=https://host.docker.internal:6443

                    kubectl --kubeconfig=/root/.kube/config cluster-info || { echo "Cannot reach cluster"; exit 1; }
                    kubectl --kubeconfig=/root/.kube/config get nodes || { echo "Cannot list nodes"; exit 1; }

                    echo "Deploying to Kubernetes..."
                    kubectl --kubeconfig=/root/.kube/config apply -f k8s/deployment.yaml --validate=false
                    kubectl --kubeconfig=/root/.kube/config apply -f k8s/service.yaml --validate=false

                    echo "Waiting for rollout..."
                    kubectl --kubeconfig=/root/.kube/config rollout status deployment/devops-demo
                '''
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
