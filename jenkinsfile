pipeline {
    agent any

    environment {
        IMAGE_NAME = 'local/devops-demo'
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout([$class: 'GitSCM',
                          branches: [[name: 'refs/heads/main']],
                          userRemoteConfigs: [[url: 'https://github.com/muchabiseki/devops-demo.git']]])
                sh 'ls -l'
                sh 'ls -l tests'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def appDir = 'app' // folder containing Dockerfile
                    dockerImage = docker.build("${env.IMAGE_NAME}:${env.BUILD_NUMBER}", "-f ${appDir}/Dockerfile ${appDir}")
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    docker.image("${env.IMAGE_NAME}:${env.BUILD_NUMBER}").inside("-v ${env.WORKSPACE}/tests:/tests") {
                        sh '''
                            echo "Listing /tests directory contents inside container:"
                            ls -l /tests
                            pytest -v /tests
                        '''
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    docker.image('bitnami/kubectl:latest').inside("-v $HOME/.kube:/root/.kube") {
                        sh '''
                            kubectl apply -f k8s/deployment.yaml
                            kubectl apply -f k8s/service.yaml
                            kubectl rollout status deployment/devops-demo
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
