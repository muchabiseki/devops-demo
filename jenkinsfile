pipeline {
    agent {
        docker {
            image 'bitnami/kubectl:latest'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        IMAGE_NAME = 'local/devops-demo'
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout([$class: 'GitSCM',
                          branches: [[name: 'refs/heads/main']],
                          userRemoteConfigs: [[url: 'https://github.com/muchabiseki/devops-demo.git']]])
                sh 'ls -l'
                sh 'ls -l app'
                sh 'ls -l k8s'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def appDir = 'app' // folder containing Dockerfile
                    dockerImage = docker.build("${env.IMAGE_NAME}:${env.BUILD_NUMBER}", "-f ${appDir}/Dockerfile ${appDir}")
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    // If you add tests back, mount them like this
                    // docker.image("${env.IMAGE_NAME}:${env.BUILD_NUMBER}").inside("-v ${env.WORKSPACE}/tests:/tests") {
                    //     sh 'pytest -v /tests'
                    // }
                    echo 'Skipping tests for now'
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    // Apply deployment & service YAML directly from workspace
                    sh '''
                        echo "Checking cluster connectivity..."

                        kubectl cluster-info
                        kubectl get nodes

                        echo "Deploying to Kubernetes..."
                        kubectl apply -f k8s/deployment.yaml --validate=false
                        kubectl apply -f k8s/service.yaml --validate=false

                        echo "Waiting for rollout..."
                        kubectl rollout status deployment/devops-demo
                    '''
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
